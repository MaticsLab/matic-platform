# Database Configuration (Required)
# Core app data (Railway Postgres service "AppDB")
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Better Auth database (Railway Postgres service "AuthDB"). Schema is managed with
# Drizzle Kit — see drizzle.config.ts and src/drizzle/schemas/auth-schema.ts.
# Falls back to DATABASE_URL if unset.
BETTER_AUTH_DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Better Auth Configuration (Required for authentication)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# App URLs
NEXT_PUBLIC_APP_URL=https://www.maticsapp.com
BETTER_AUTH_URL=https://www.maticsapp.com

# Go Backend Configuration
NEXT_PUBLIC_GO_API_URL=https://api.maticsapp.com
GO_BACKEND_URL=http://localhost:8080

# Supabase Configuration (file storage only — being migrated to Railway buckets)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email Configuration
EMAIL_FROM=portal<hello@notifications.maticsapp.com>
RESEND_API_KEY=your-resend-api-key

# OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe (subscriptions via the Better Auth stripe plugin)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_BASIC_PRICE_ID=price_your-basic-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# Node Environment
NODE_ENV=production
