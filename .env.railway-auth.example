# Railway-only Better Auth database configuration
# Use this with your existing .env.local values.

# Dedicated Better Auth DB on Railway
BETTER_AUTH_DATABASE_URL=postgresql://postgres:<RAILWAY_PASSWORD>@<RAILWAY_PUBLIC_HOST>:<RAILWAY_PUBLIC_PORT>/railway?sslmode=require

# Better Auth runtime
BETTER_AUTH_SECRET=<GENERATE_WITH_OPENSSL_RAND_BASE64_32>
BETTER_AUTH_URL=http://localhost:3000

# Optional fallback app DB (if you want same DB for app + auth)
# DATABASE_URL=postgresql://postgres:<RAILWAY_PASSWORD>@<RAILWAY_PUBLIC_HOST>:<RAILWAY_PUBLIC_PORT>/railway?sslmode=require
