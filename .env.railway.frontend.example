# Railway Frontend service variables
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://<frontend-domain>
NEXT_PUBLIC_GO_API_URL=https://<backend-domain>/api/v1

# Better Auth
BETTER_AUTH_URL=https://<frontend-domain>
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
BETTER_AUTH_DATABASE_URL=${{AuthDB.DATABASE_URL}}

# Better Auth Infra (dash/sentinel plugins) — frontend service only, not go-backend
BETTER_AUTH_API_KEY=<better-auth-infra-api-key>

# App DB (optional separate DB from auth)
DATABASE_URL=${{AppDB.DATABASE_URL}}

# Supabase
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Optional
RESEND_API_KEY=<resend-key>
EMAIL_FROM=<from-email>
